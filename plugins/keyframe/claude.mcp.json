{
  "mcpServers": {
    "keyframe": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--python",
        "3.12",
        "--from",
        "git+https://github.com/MatthewOscar/Keyframe.git@v0.1.0",
        "video-context-mcp",
        "serve",
        "--transport",
        "stdio"
      ],
      "timeout": 1900000
    }
  }
}
