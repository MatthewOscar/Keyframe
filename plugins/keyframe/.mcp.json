{
  "mcpServers": {
    "keyframe": {
      "command": "uvx",
      "args": [
        "--python",
        "3.12",
        "--from",
        "video-context-mcp[whisper] @ git+https://github.com/MatthewOscar/Keyframe.git@v0.1.1",
        "video-context-mcp",
        "serve",
        "--transport",
        "stdio"
      ],
      "env": {
        "KEYFRAME_ALLOW_TEMP_UPLOADS": "true"
      },
      "startup_timeout_sec": 180,
      "tool_timeout_sec": 1900
    }
  }
}
