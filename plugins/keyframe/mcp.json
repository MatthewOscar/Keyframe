{
  "mcpServers": {
    "keyframe": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--python",
        "3.12",
        "--from",
        "video-context-mcp[whisper]==0.2.6",
        "video-context-mcp",
        "serve",
        "--transport",
        "stdio"
      ],
      "env": {
        "KEYFRAME_ALLOW_TEMP_UPLOADS": "true"
      }
    }
  }
}
