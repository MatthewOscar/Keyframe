{
  "mcpServers": {
    "keyframe": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--project",
        "${CLAUDE_PROJECT_DIR:-.}",
        "video-context-mcp",
        "serve",
        "--transport",
        "stdio"
      ],
      "env": {
        "KEYFRAME_ALLOW_TEMP_UPLOADS": "true"
      },
      "timeout": 1900000
    }
  }
}
