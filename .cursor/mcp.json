{
  "mcpServers": {
    "keyframe": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--project",
        ".",
        "video-context-mcp",
        "serve",
        "--transport",
        "stdio"
      ],
      "env": {
        "KEYFRAME_ALLOW_TEMP_UPLOADS": "true"
      }
    }
  }
}
